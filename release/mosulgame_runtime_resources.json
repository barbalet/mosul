{
  "schema_version": 1,
  "release_scope": {
    "product_target": "MosulGame",
    "scheme": "MosulGame",
    "app_bundle": "MosulGame.app",
    "executable": "MosulGame",
    "bundle_identifier": "com.barbalet.mosulgame",
    "display_name": "MosulGame",
    "public_release_name": "MOSUL",
    "minimum_macos": "14.0",
    "architectures": [
      "arm64",
      "x86_64"
    ],
    "default_scenario": "modernerKrieg/game/mosul/scenarios/market_commercial_streets_2003.mkscenario",
    "runtime_bundle_root": "Contents/Resources/mosul-runtime"
  },
  "required_files": [
    "MosulGame.xcodeproj/project.pbxproj",
    "Mac/Mosul/App/MosulApp.swift",
    "Mac/Mosul/App/MosulVersion.swift",
    "Mac/Mosul/App/MosulAudioController.swift",
    "Mac/Mosul/App/MosulGameModel.swift",
    "Mac/Mosul/App/TacticalMapView.swift",
    "Mac/Mosul/Bridge/MosulEngineBridge.c",
    "Mac/Mosul/Bridge/MosulEngineBridge.h",
    "scripts/copy_mosulgame_runtime_resources.py",
    "modernerKrieg/assets/mosul/manifests/market_commercial_streets_2003.mapmanifest",
    "modernerKrieg/assets/mosul/manifests/market_commercial_streets_2003_building_levels.json",
    "modernerKrieg/assets/mosul/manifests/market_commercial_streets_2003_topology.json",
    "modernerKrieg/assets/mosul/manifests/mosul_2003_markers.markermanifest",
    "modernerKrieg/assets/mosul/manifests/mosul_2003_sprites.spritemanifest",
    "modernerKrieg/assets/mosul/audio/mosul_audio_manifest.json",
    "modernerKrieg/assets/mosul/audio/CREDITS.md",
    "modernerKrieg/game/mosul/scenarios/market_commercial_streets_2003.mkscenario"
  ],
  "required_directories": [
    "modernerKrieg/assets/mosul/audio",
    "modernerKrieg/assets/mosul/runtime/maps/market_commercial_streets_2003",
    "modernerKrieg/assets/mosul/runtime/sprites/rendered"
  ],
  "derived_runtime_inputs": {
    "scenario_asset_keys": [
      "asset.map_manifest",
      "asset.sprite_manifest",
      "asset.building_level_manifest",
      "asset.topology_manifest"
    ],
    "map_manifest_runtime_keys": [
      "runtime_overview_path"
    ],
    "building_level_png_key": "png",
    "sprite_manifest_runtime_keys": [
      "runtime_pipeline_manifest",
      "runtime_render_manifest"
    ],
    "sprite_render_manifest_array": "rendered",
    "sprite_render_manifest_path_key": "path"
  },
  "audio_runtime": {
    "manifest": "modernerKrieg/assets/mosul/audio/mosul_audio_manifest.json",
    "credits": "modernerKrieg/assets/mosul/audio/CREDITS.md",
    "allowed_buses": [
      "ambience",
      "tactical",
      "radio",
      "ui"
    ],
    "allowed_kinds": [
      "loop",
      "one_shot",
      "voice"
    ],
    "allowed_licenses": [
      "CC0-1.0",
      "CC-BY-3.0",
      "CC-BY-4.0",
      "Original",
      "Commissioned",
      "US-GOV-PD"
    ],
    "allowed_extensions": [
      ".wav",
      ".aif",
      ".aiff",
      ".caf",
      ".m4a",
      ".aac"
    ],
    "allowed_sample_rates": [
      44100,
      48000
    ],
    "allowed_channels": [
      1,
      2
    ]
  },
  "excluded_from_standalone_bundle": [
    "modernerKrieg/assets/mosul/source",
    "modernerKrieg/assets/mosul/runtime/maps/market_commercial_streets_2003/candidates",
    "modernerKrieg/build",
    "build",
    "snapshots"
  ]
}
